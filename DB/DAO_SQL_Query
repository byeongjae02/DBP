-- 1. 로그인 확인
-- 사용 DAO: UserDAO
-- 사용 기능: 로그인
SELECT user_id, name, role
FROM users
WHERE user_id = ? AND password = ?;


-- 2. 아이디 중복 확인
-- 사용 DAO: UserDAO
-- 사용 기능: 회원가입 전 중복 검사
SELECT COUNT(*) AS count
FROM users
WHERE user_id = ?;


-- 3. 회원 계정 추가
-- 사용 DAO: UserDAO
-- 사용 기능: 회원가입
INSERT INTO users(user_id, password, name, role)
VALUES (?, ?, ?, ?);


-- 4. 랩원 상세 정보 추가
-- 사용 DAO: MemberDAO
-- 사용 기능: 회원가입 시 랩원 정보 저장
INSERT INTO members(
    user_id,
    name,
    student_id,
    department,
    email,
    phone,
    lab_role,
    member_status,
    research_field
)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?);


-- 5. 전체 랩원 목록 조회
-- 사용 DAO: MemberDAO
-- 사용 기능: 랩원 목록 페이지
SELECT 
    member_id,
    user_id,
    name,
    student_id,
    department,
    email,
    phone,
    lab_role,
    member_status,
    research_field
FROM members
ORDER BY member_id;


