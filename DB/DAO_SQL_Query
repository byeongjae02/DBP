-- 11. 프로젝트 참여자 조회
-- 사용 DAO: ProjectDAO 또는 ProjectMemberDAO
-- 사용 기능: 프로젝트 상세 페이지에서 참여 랩원 표시
SELECT 
    p.project_id,
    p.project_name,
    p.project_type,
    m.member_id,
    m.name,
    m.department,
    pm.project_role,
    pm.joined_date
FROM project_members pm
JOIN projects p ON pm.project_id = p.project_id
JOIN members m ON pm.member_id = m.member_id
WHERE p.project_id = ?
ORDER BY m.member_id;


-- 12. 전체 프로젝트-참여자 관계 조회
-- 사용 DAO: ProjectDAO 또는 ProjectMemberDAO
-- 사용 기능: 프로젝트 참여 현황 확인
SELECT 
    p.project_name,
    p.project_type,
    m.name,
    pm.project_role,
    pm.joined_date
FROM project_members pm
JOIN projects p ON pm.project_id = p.project_id
JOIN members m ON pm.member_id = m.member_id
ORDER BY p.project_id, m.member_id;


-- 13. 최근 공지사항 3개 조회
-- 사용 DAO: NoticeDAO
-- 사용 기능: 메인 페이지 최근 공지사항 표시
SELECT 
    notice_id,
    title,
    content,
    writer,
    created_at
FROM notices
ORDER BY notice_id DESC
LIMIT 3;


-- 14. 전체 공지사항 목록 조회
-- 사용 DAO: NoticeDAO
-- 사용 기능: 공지사항 목록 페이지
SELECT 
    notice_id,
